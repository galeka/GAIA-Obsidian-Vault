# GAIA — Environment Variables Template
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env in your vault root and fill in your credentials.
# .env is gitignored and will NEVER be committed to the repo.
#
# RECOMMENDED: Use system environment variables instead (see docs/lark-setup-guide.md).
# System env vars take priority over this file automatically.
# ──────────────────────────────────────────────────────────────────────────────

# ── Lark (required for lark-sync agent) ───────────────────────────────────────
LARK_APP_ID=your_app_id_here
LARK_APP_SECRET=your_app_secret_here

# Optional: direct tenant token (skips App ID/Secret auth — advanced use only)
# LARK_API_TOKEN=

# Optional: override API base for Lark China edition
# LARK_API_BASE=https://open.feishu.cn

# ── Gmail / Google Calendar (required for postman agent) ─────────────────────
# Configured via .mcp.json — see docs/gws-setup-guide.md

# ── MCP server settings (optional) ───────────────────────────────────────────
# MCP_PORT=8000
# MCP_HOST=127.0.0.1
