# Lark Bot Credentials
LARK_APP_ID=your_lark_app_id_here
LARK_APP_SECRET=your_app_secret_here
LARK_BOT_ID=your_bot_id_here

# AChatGPT Configuration
ACHATGPT_API_KEY=your_achatgpt_api_key

# Vault Path (optional — auto-detects on macOS/Windows/Linux if omitted)
# Windows example: C:\Users\YourName\OneDrive\Documents\Obsidian Vault\MyVault
# macOS example:  /Users/yourname/Library/Mobile Documents/iCloud~md~obsidian/Documents/MyVault
# Linux example:  /home/yourname/Obsidian/MyVault
VAULT_ROOT=

# Path to achat.sh (optional — defaults to ./achat.sh)
ACHAT_SCRIPT=./achat.sh
